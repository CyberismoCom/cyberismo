{
  "name": "@cyberismo/app",
  "private": true,
  "version": "0.0.2",
  "license": "AGPL-3.0",
  "scripts": {
    "clean": "rm -rf node_modules",
    "unit": "vitest run",
    "unit:watch": "vitest",
    "setup-e2e": "node scripts/setup-e2e.js",
    "e2e": "pnpm setup-e2e && start-server-and-test test-env-dev http://localhost:3000 \"cypress open --e2e\"",
    "e2e:app": "pnpm setup-e2e && start-server-and-test test-env-dev http://localhost:3000 \"cypress run --e2e --spec cypress/e2e/app.cy.ts\"",
    "e2e:macros": "pnpm setup-e2e && start-server-and-test test-env-dev http://localhost:3000 \"cypress run --e2e --spec cypress/e2e/macros.cy.ts\"",
    "e2e:xss": "pnpm setup-e2e && start-server-and-test test-env-dev http://localhost:3000 \"cypress run --e2e --spec cypress/e2e/xss.cy.ts\"",
    "e2e:headless": "pnpm e2e:app && pnpm e2e:macros && pnpm e2e:xss",
    "test-env-dev": "cross-env NODE_ENV=test npm_config_project_path=../../.tmp/cyberismo-bat pnpm --filter backend start-e2e",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "start": "vite",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "pnpm run unit && pnpm e2e:headless"
  },
  "devDependencies": {
    "@asciidoctor/core": "^3.0.4",
    "@codemirror/commands": "^6.10.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "6.39.12",
    "@cyberismo/data-handler": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.7",
    "@mui/joy": "5.0.0-beta.52",
    "@mui/material": "^7.3.8",
    "@reduxjs/toolkit": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@uiw/codemirror-theme-github": "^4.25.5",
    "@uiw/codemirror-theme-vscode": "^4.25.4",
    "@uiw/react-codemirror": "^4.25.4",
    "@vitejs/plugin-react": "^5.1.4",
    "codemirror-asciidoc": "^2.0.1",
    "cypress": "^15.13.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "global-jsdom": "^26.0.0",
    "globals": "^17.4.0",
    "html-react-parser": "^5.2.17",
    "i18next": "^26.0.3",
    "jsdom": "^29.0.1",
    "node-html-parser": "^7.0.2",
    "react": "^19.2.4",
    "react-arborist": "^3.4.3",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.2",
    "react-redux": "^9.2.0",
    "react-resizable-panels": "^4.7.0",
    "react-router": "^7.14.0",
    "react-vega": "^8.0.0",
    "redux-persist": "^6.0.0",
    "rollup-plugin-license": "^3.6.0",
    "start-server-and-test": "^2.1.5",
    "swr": "^2.4.1",
    "vega": "^6.2.0",
    "vega-lite": "^6.4.2",
    "vite": "^8.0.8",
    "zod": "^4.3.6"
  }
}
