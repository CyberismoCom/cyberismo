{
  "name": "@cyberismo/node-clingo",
  "version": "1.6.0",
  "description": "Node.js bindings for Clingo answer set solver",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:clingo": "cmake -P scripts/build-clingo.cmake",
    "build:binding": "node-gyp rebuild",
    "build:native": "pnpm run build:clingo && pnpm run build:binding",
    "bump-version": "node scripts/bump-version.js",
    "install": "pnpm run build:native",
    "prepack": "node scripts/manage-publish-manifest.js strip",
    "postpack": "node scripts/manage-publish-manifest.js restore",
    "clean": "rm -rf build dist dist-packages external/clingo/build",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format:cpp": "clang-format -i src/*.cc src/*.h",
    "format:cpp:check": "clang-format --dry-run --Werror src/*.cc src/*.h"
  },
  "keywords": [],
  "author": "sami.merila@cyberismo.com",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/CyberismoCom/cyberismo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CyberismoCom/cyberismo.git"
  },
  "bugs": "https://github.com/CyberismoCom/cyberismo/issues",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "node-addon-api": "^8.7.0"
  },
  "optionalDependencies": {
    "@cyberismo/node-clingo-linux-x64-gnu": "1.6.0",
    "@cyberismo/node-clingo-linux-x64-musl": "1.6.0",
    "@cyberismo/node-clingo-linux-arm64-gnu": "1.6.0",
    "@cyberismo/node-clingo-linux-arm64-musl": "1.6.0",
    "@cyberismo/node-clingo-darwin-x64": "1.6.0",
    "@cyberismo/node-clingo-darwin-arm64": "1.6.0",
    "@cyberismo/node-clingo-win32-x64": "1.6.0"
  },
  "devDependencies": {
    "node-gyp": "^12.2.0",
    "semver": "^7.7.0"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "lib",
    "LICENSE.md",
    "THIRD-PARTY.txt"
  ]
}
