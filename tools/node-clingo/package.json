{
  "name": "@cyberismo/node-clingo",
  "version": "1.6.0-rc.0",
  "description": "Node.js bindings for Clingo answer set solver",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:native": "cmake -P scripts/build-clingo.cmake && node-gyp rebuild",
    "install": "node -e \"\"",
    "clean": "rm -rf build dist dist-packages external/clingo/build",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format:cpp": "clang-format -i src/*.cc src/*.h",
    "format:cpp:check": "clang-format --dry-run --Werror src/*.cc src/*.h"
  },
  "keywords": [],
  "author": "sami.merila@cyberismo.com",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/CyberismoCom/cyberismo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CyberismoCom/cyberismo.git"
  },
  "bugs": "https://github.com/CyberismoCom/cyberismo/issues",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "node-addon-api": "^8.7.0"
  },
  "devDependencies": {
    "node-gyp": "^12.2.0"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "lib",
    "LICENSE.md",
    "THIRD-PARTY.txt"
  ]
}
