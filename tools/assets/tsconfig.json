{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "incremental": true,
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"],
    "resolveJsonModule": true,
    "esModuleInterop": true
  }
}
